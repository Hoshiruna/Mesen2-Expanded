<UserControl
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:vm="using:Mesen.ViewModels"
	xmlns:c="using:Mesen.Controls"
	mc:Ignorable="d" d:DesignWidth="610" d:DesignHeight="250"
	VerticalAlignment="Stretch"
	HorizontalAlignment="Stretch"
	x:DataType="vm:KeyMappingViewModel"
	x:Class="Mesen.Views.GenesisControllerView"
>
	<Design.DataContext>
		<vm:KeyMappingViewModel />
	</Design.DataContext>

	<Border BorderBrush="{StaticResource MesenGrayBorderColor}" BorderThickness="2" Padding="3" Width="610" Height="250" HorizontalAlignment="Left" VerticalAlignment="Top">
		<Canvas>
			<Panel Canvas.Top="20">
				<Ellipse Width="200" Height="200" Stroke="{StaticResource MesenGrayBorderColor}" StrokeThickness="2" />
				<Grid ColumnDefinitions="*,*" RowDefinitions="*,*,*" Width="200" Height="200">
					<c:KeyBindingButton KeyBinding="{Binding Mapping.Up}" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Width="80" Height="40" HorizontalAlignment="Center" />
					<c:KeyBindingButton KeyBinding="{Binding Mapping.Left}" Grid.Row="1" Grid.Column="0" Width="80" Height="40" HorizontalAlignment="Center" />
					<c:KeyBindingButton KeyBinding="{Binding Mapping.Right}" Grid.Row="1" Grid.Column="1" Width="80" Height="40" HorizontalAlignment="Center" />
					<c:KeyBindingButton KeyBinding="{Binding Mapping.Down}" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Width="80" Height="40" HorizontalAlignment="Center" />
				</Grid>
			</Panel>

			<Panel Canvas.Top="35" Canvas.Right="0">
				<Ellipse Width="240" Height="170" Fill="{StaticResource MesenGrayBackgroundColor}" />
				<StackPanel Orientation="Vertical" Width="210" Margin="15 10 0 0">
					<StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
						<c:ControllerButton Width="60" Margin="2 0" Label="X" KeyBinding="{Binding Mapping.X}" HasTurbo="False" />
						<c:ControllerButton Width="60" Margin="2 0" Label="Y" KeyBinding="{Binding Mapping.Y}" HasTurbo="False" />
						<c:ControllerButton Width="60" Margin="2 0" Label="Z" KeyBinding="{Binding Mapping.TurboB}" HasTurbo="False" />
					</StackPanel>
					<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 12 0 0">
						<c:ControllerButton Width="60" Margin="2 0" Label="A" KeyBinding="{Binding Mapping.A}" HasTurbo="False" />
						<c:ControllerButton Width="60" Margin="2 0" Label="B" KeyBinding="{Binding Mapping.B}" HasTurbo="False" />
						<c:ControllerButton Width="60" Margin="2 0" Label="C" KeyBinding="{Binding Mapping.TurboA}" HasTurbo="False" />
					</StackPanel>
				</StackPanel>
			</Panel>

			<Grid ColumnDefinitions="*,Auto,Auto,*" RowDefinitions="Auto,Auto" Width="580" Canvas.Bottom="10">
				<c:KeyBindingButton KeyBinding="{Binding Mapping.Select}" Grid.Column="1" Width="80" />
				<TextBlock Grid.Column="1" Grid.Row="1" Text="Mode" FontSize="14" HorizontalAlignment="Center" />

				<c:KeyBindingButton KeyBinding="{Binding Mapping.Start}" Grid.Column="2" Width="80" />
				<TextBlock Grid.Column="2" Grid.Row="1" Text="Start" FontSize="14" HorizontalAlignment="Center" />
			</Grid>
		</Canvas>
	</Border>
</UserControl>
